# Copy to `secrets.toml` in this folder for local tests (file is gitignored).
# On Streamlit Community Cloud: App → Edit secrets → paste the same TOML keys.
#
# --- Recommended: weights on Hugging Face Hub (keeps GitHub repo small) ---
# Create a "model" repo upload: weights/best_model.pth
HF_REPO = "your-username/your-retinascreen-weights"
HF_MODEL_FILE = "weights/best_model.pth"

# Optional: private Hub repo or higher API rate limits
# HF_TOKEN = "hf_xxxxxxxx"

# If HF_REPO is unset, the app uses ./weights/best_model.pth next to app.py (local / Docker only).
